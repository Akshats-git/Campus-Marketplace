# Copy this file to .env and fill in your values.
# See SETUP.md for instructions on where to get each key.

# Firebase Config (from Firebase Console → Project Settings → Your apps)
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSy...
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123:android:abc
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXX

# Google Sign-In Web Client ID (Firebase Console → Auth → Google → Web SDK config)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=123456789-abc.apps.googleusercontent.com

# Cloudinary (cloudinary.com → Dashboard → Cloud Name; Settings → Upload → Add unsigned preset)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset

# Gemini API Key (aistudio.google.com → Get API Key)
EXPO_PUBLIC_GEMINI_API_KEY=AIzaSy...
